APP_NAME=Dujiaoka
APP_ENV=production
APP_KEY=base64:P2TSsFMYpp3/G4DRdqWpCwe6R3phEd1abHzxbLj/kDU=
APP_DEBUG=false
APP_URL=https://your-domain.example

LOG_CHANNEL=stack

# Docker Compose variables
INSTALL=false
TZ=Asia/Shanghai
APP_PORT=8080
DB_ROOT_PASSWORD=change_me_root

# Application database settings
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=dujiaoka
DB_USERNAME=dujiaoka
DB_PASSWORD=change_me_app

# Application redis settings
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

BROADCAST_DRIVER=log
SESSION_DRIVER=file
SESSION_LIFETIME=120

# file 为磁盘文件, redis 为内存级别
CACHE_DRIVER=redis

# sync 为同步, redis 为异步
QUEUE_CONNECTION=redis

# zh_CN / zh_TW / en
DUJIAO_ADMIN_LANGUAGE=zh_CN

# 后台登录地址
ADMIN_ROUTE_PREFIX=admin

# 如果前端走 HTTPS, 这里也改成 true
ADMIN_HTTPS=true
